# Hive configuration — copy to config/.env and fill in.
# Nothing here is required to START (sane defaults); set what you use.
# config/.env is gitignored — never commit real values.

# ── Models / runtime ───────────────────────────────────────────────────
# Ollama endpoint (local by default). The installer installs Ollama for you.
OLLAMA_HOST=127.0.0.1:11434
# Which GPU(s) Ollama may use. Leave unset for all; e.g. "0" or "0,1" to pin.
# CUDA_VISIBLE_DEVICES=
# OLLAMA_NUM_GPU=

# Optional cloud tier — only if you want the cloud models in model_catalog.yaml.
# ANTHROPIC_API_KEY=<PLACEHOLDER>
# OPENAI_API_KEY=<PLACEHOLDER>

# ── Paths (default to repo-relative; change if your data lives elsewhere) ─
HIVE_VAULT_PATH=./vault
HIVE_PROJECTS_ROOT=~/projects
# HIVE_PROMPTS=./prompts

# ── Optional features (OFF by default) ─────────────────────────────────
# Discord bots — leave blank to run without them.
# DISCORD_BOT_TOKEN=<PLACEHOLDER>
# SCOUT_BOT_TOKEN=<PLACEHOLDER>
# MAGGY_BOT_TOKEN=<PLACEHOLDER>
# HIVE_OWNER_DISCORD_ID=
# PROACTIVE_HIVE_ENABLED=false

# Image generation (civitai/LoRA) — optional; leave unset to disable.
# HIVE_IMAGE_APP_ROOT=
# HIVE_IMAGE_BACKEND_PATH=      # path to imageToVideo checkout; enables image-gen routes
# HIVE_VIDEO_BACKEND_PATH=      # path to videoGen checkout; enables video routes

# ── Optional integrations ───────────────────────────────────────────────────
# Gitea backup for the vault (set remote in config/vault-writer.yaml too).
# GITEA_TOKEN=<PLACEHOLDER>     # personal access token for vault git backup
# CIVITAI_API_KEY=<PLACEHOLDER> # fetch LoRA weights from CivitAI
# COMPOSIO_API_KEY=<PLACEHOLDER> # enables Composio-managed tool calls
# HIVE_APK_PATH=                # directory where built APKs are served

# Audio/video capture device IDs (used by the media helpers).
# VOICE_DEVICE=                 # e.g. "Microphone (USB Audio)"
# VIDEO_DEVICE=                 # e.g. "HD Webcam C270"
